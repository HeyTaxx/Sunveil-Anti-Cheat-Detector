<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>CheatDetector</AssemblyName>
    <RootNamespace>CheatDetector</RootNamespace>
    <Version>1.0.0</Version>
    <Authors>BlueStyle.dev</Authors>
    <Description>Minecraft Cheat Detection Scanner - Forensic PC Analysis Tool</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Management" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\..\signatures.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>signatures.json</Link>
    </Content>
  </ItemGroup>

</Project>
