# Server Configuration
PORT=3000
NODE_ENV=production

# Security & Encryption (Generate strong random keys for production)
# Example: openssl rand -base64 32
AES_ENCRYPTION_KEY="INSERT_YOUR_32_BYTE_KEY_HERE"

# API Authentication (Optional: require API key from scanner)
REQUIRE_API_KEY=true
SCANNER_API_KEY="INSERT_SECURE_TOKEN_HERE"

