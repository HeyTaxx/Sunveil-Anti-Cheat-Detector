# ══════════════════════════════════════════
#  Sunveil SMP Anti-Cheat — API Config
#  Copy to .env and fill in your values.
#  .env is gitignored — never commit it.
# ══════════════════════════════════════════

# Server
PORT=3000

# Path to the flat-file JSON database
DB_PATH=./cheatdetector_db.json

# Path to signatures.json (absolute or relative to api/)
SIGNATURES_PATH=../signatures.json

# CORS origin whitelist (comma-separated, or * for all)
CORS_ORIGIN=*

# Maximum report body size accepted by the API
MAX_BODY_SIZE=10mb
